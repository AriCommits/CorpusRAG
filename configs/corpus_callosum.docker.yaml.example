paths:
  vault: /app/vault
  chromadb_store: /app/chroma_store

embedding:
  model: sentence-transformers/all-MiniLM-L6-v2

model:
  endpoint: http://host.docker.internal:11434/api/generate
  name: llama3
  timeout_seconds: 120.0
  max_flashcard_context_chars: 12000

chunking:
  size: 500
  overlap: 50

retrieval:
  top_k_semantic: 10
  top_k_bm25: 10
  top_k_final: 5
  rrf_k: 60

server:
  host: 0.0.0.0
  port: 8080

chroma:
  mode: http
  host: chroma
  port: 8000
  ssl: false

# Security settings (optional - defaults shown)
security:
  # Rate limiting
  rate_limit_enabled: true
  requests_per_minute: 60
  requests_per_hour: 1000
  burst_limit: 10  # max requests per second

  # API key authentication (disabled by default)
  auth_enabled: false
  api_keys: []  # List of API keys (or hashed keys if api_keys_hashed is true)
  api_keys_hashed: false  # Set to true if keys in api_keys are SHA-256 hashes

# Observability settings (OpenTelemetry + OpenLLMetry)
# Requires: pip install corpus-callosum[observability]
observability:
  enabled: true  # Set to true to enable tracing
  service_name: corpus-callosum
  otlp_endpoint: http://otel-collector:4317  # e.g., "http://otel-collector:4317" for OTLP collector
  console_exporter: false  # Set to true for development debugging
  openllmetry_enabled: true  # Enable LLM-specific tracing

# Postgres settings (for observability backend)
postgres:
  user: otel
  password: changeme_secure_password
  database: otel_traces

