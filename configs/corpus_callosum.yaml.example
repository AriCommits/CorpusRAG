paths:
  vault: ./vault
  chromadb_store: ./chroma_store

embedding:
  model: sentence-transformers/all-MiniLM-L6-v2

model:
  endpoint: http://localhost:11434
  # name: llama3  # Optional - auto-detects first available model from Ollama if not specified
  timeout_seconds: 120.0
  max_flashcard_context_chars: 12000

chunking:
  size: 500
  overlap: 50

retrieval:
  top_k_semantic: 10
  top_k_bm25: 10
  top_k_final: 5
  rrf_k: 60

server:
  host: 127.0.0.1
  port: 8080

chroma:
  mode: persistent  # 'persistent' for local storage, 'http' for remote ChromaDB
  host: localhost
  port: 8000
  ssl: false

# Security settings (optional - defaults shown)
security:
  # Rate limiting
  rate_limit_enabled: true
  requests_per_minute: 60
  requests_per_hour: 1000
  burst_limit: 10  # max requests per second

  # API key authentication (enabled by default)
  auth_enabled: true
  api_keys: []  # List of SHA-256 hashed API keys
  api_keys_hashed: true  # Keys in api_keys are SHA-256 hashes

# Observability settings (OpenTelemetry + OpenLLMetry)
# Requires: pip install corpus-callosum[observability]
observability:
  enabled: false  # Set to true to enable tracing
  service_name: corpus-callosum
  otlp_endpoint: null  # e.g., "http://localhost:4317" for OTLP collector
  console_exporter: false  # Set to true for development debugging
  openllmetry_enabled: true  # Enable LLM-specific tracing
