# CorpusCallosum Environment Variables
# Copy to .env and fill in values. DO NOT commit .env to version control.

# Postgres (observability backend)
POSTGRES_USER=otel
POSTGRES_PASSWORD=
POSTGRES_DB=otel_traces

# Vault (secrets management)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# API Keys (if not using Vault)
CORPUS_API_KEYS=

# Model API Keys (if not using Vault)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
