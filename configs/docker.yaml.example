llm:
  endpoint: http://host.docker.internal:11434
  model: llama3
  backend: ollama
  timeout_seconds: 120.0
  temperature: 0.7
  max_tokens: null
  api_key: null
  fallback_models: []

embedding:
  backend: sentence-transformers
  model: sentence-transformers/all-MiniLM-L6-v2
  dimensions: null

database:
  backend: chromadb
  mode: http
  host: chromadb
  port: 8000
  persist_directory: /app/chroma_store

paths:
  vault: /app/vault
  scratch_dir: /app/scratch
  output_dir: /app/output

rag:
  chunking:
    size: 500
    overlap: 50
  retrieval:
    top_k_semantic: 10
    top_k_bm25: 10
    top_k_final: 5
    rrf_k: 60
  collection_prefix: rag
