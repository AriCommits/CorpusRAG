# Copy to .env and fill in values
CHROMA_TOKEN=replace_with_strong_token

# Absolute path to your Obsidian vault (set per machine)
# Mac example:  VAULT_PATH=/Volumes/OBSIDIAN_USB/Vault
# Win example:  VAULT_PATH=E:/Vault
VAULT_PATH=/path/to/your/vault

# Absolute path to your model directory
# Mac example:  MODEL_STORE=/Users/you/ModelStore
# Win example:  MODEL_STORE=D:/ModelStore
MODEL_STORE=/path/to/your/models